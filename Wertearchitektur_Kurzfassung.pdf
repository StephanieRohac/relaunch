<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dr. Stephanie Rohac — Culture Drives Change</title>
<style>
  @import url('https://cdn.jsdelivr.net/npm/@fontsource/inter@5.1.0/400.css');
  @import url('https://cdn.jsdelivr.net/npm/@fontsource/inter@5.1.0/500.css');
  @import url('https://cdn.jsdelivr.net/npm/@fontsource/lora@5/400.css');
  @import url('https://cdn.jsdelivr.net/npm/@fontsource/lora@5/400-italic.css');
  @import url('https://cdn.jsdelivr.net/npm/@fontsource/lora@5/700.css');

  :root {
    --tintenblau: #1A3240;
    --petrol-mid: #2E5666;
    --petrol-mist: #4A7C8E;
    --nebelblau: #8EB0C0;
    --himmelblau: #D5E2E8;
    --pergament: #F4EFE5;
    --sandstein: #EEE5D3;
    --leinen: #C4BBA8;
    --graphit: #2E281F;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --serif: 'Lora', Georgia, serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    background: var(--pergament);
    color: var(--tintenblau);
    -webkit-font-smoothing: antialiased;
  }

  /* === NAV === */
  nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(26,50,64,0.97);
    backdrop-filter: blur(12px);
  }
  .nav-inner {
    max-width: 1240px; margin: 0 auto;
    padding: 16px 48px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .brand-link {
    display: flex; align-items: center; gap: 14px;
    text-decoration: none; color: var(--pergament);
  }
  .brand-logo { width: 38px; height: 27px; object-fit: contain; }
  .brand-name-nav { font-size: 14px; font-weight: 500; letter-spacing: 0.01em; }
  .nav-links { display: flex; gap: 28px; align-items: center; }
  .nav-links a {
    font-size: 12px; font-weight: 500; color: var(--nebelblau);
    text-decoration: none; letter-spacing: 0.04em; transition: color 180ms;
  }
  .nav-links a:hover { color: var(--pergament); }
  .nav-cta {
    padding: 8px 18px; background: var(--pergament);
    font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
    color: var(--tintenblau); text-decoration: none; transition: all 200ms;
  }
  .nav-cta:hover { background: var(--himmelblau); }

  /* === HERO — Schicht 1: Tiefe & Menschlichkeit === */
  .hero {
    background: var(--tintenblau);
    position: relative; overflow: hidden;
    min-height: 92vh;
    display: flex; align-items: center;
  }
  /* Atmospheric wave layers */
  .hero-wave-bg {
    position: absolute; inset: 0; overflow: hidden; pointer-events: none;
  }
  .hero-wave-bg svg {
    position: absolute; bottom: 0; left: 0; width: 100%;
  }
  .hero-circle-1 {
    position: absolute; right: -80px; top: -100px;
    width: 520px; height: 520px;
    border: 1px solid var(--petrol-mid); border-radius: 50%;
    opacity: 0.18;
  }
  .hero-circle-2 {
    position: absolute; left: 10%; bottom: 15%;
    width: 300px; height: 300px;
    border: 1px solid var(--petrol-mist); border-radius: 50%;
    opacity: 0.08;
  }
  .hero-inner {
    max-width: 1240px; margin: 0 auto; width: 100%;
    padding: 80px 48px 120px;
    display: grid; grid-template-columns: 1.2fr 0.8fr;
    gap: 60px; align-items: center;
    position: relative; z-index: 2;
  }
  /* Brand hierarchy block */
  .hero-brand {
    margin-bottom: 48px;
  }
  .hero-name {
    font-family: var(--sans);
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 500; letter-spacing: -0.025em; line-height: 1.05;
    color: var(--pergament); margin-bottom: 12px;
  }
  .hero-cdc {
    font-size: 12px; font-weight: 500; letter-spacing: 0.36em;
    color: var(--petrol-mist); margin-bottom: 8px;
  }
  .hero-role {
    font-size: 11px; font-weight: 500; letter-spacing: 0.24em;
    color: var(--nebelblau); opacity: 0.7;
  }
  /* Symbol as standalone element */
  .hero-symbol {
    display: block; width: 120px; height: auto;
    margin-bottom: 40px; opacity: 0.85;
  }
  /* Editorial headline */
  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(32px, 3.6vw, 48px);
    font-weight: 400; line-height: 1.2;
    color: var(--himmelblau);
    margin-bottom: 28px;
    max-width: 14ch;
  }
  .hero-headline em {
    font-style: italic; color: var(--nebelblau);
  }
  /* Flow signature */
  .hero-flow {
    display: block; color: var(--petrol-mist); opacity: 0.4;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-family: var(--serif); font-size: 15px; font-style: italic;
    color: var(--nebelblau); line-height: 1.65; max-width: 44ch;
    opacity: 0.8;
  }
  /* Portrait */
  .hero-portrait {
    background: linear-gradient(160deg, var(--petrol-mid), var(--tintenblau));
    aspect-ratio: 3/4; position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-portrait-ph {
    color: var(--nebelblau); font-family: var(--serif);
    font-size: 13px; font-style: italic; text-align: center;
    line-height: 1.6; padding: 32px; opacity: 0.5;
  }
  .hero-portrait-ph::before {
    content: ''; display: block; width: 48px; height: 48px;
    border: 1.5px solid var(--nebelblau); border-radius: 50%;
    margin: 0 auto 14px; opacity: 0.4;
  }

  /* === WAVE TRANSITION === */
  .wave-transition {
    position: relative; height: 120px; margin-top: -1px;
  }
  .wave-transition svg {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  }
  .wave-transition-reverse {
    position: relative; height: 100px; margin-bottom: -1px;
  }
  .wave-transition-reverse svg {
    position: absolute; bottom: 0; left: 0; width: 100%; height: 100%;
  }

  /* === POSITIONIERUNG === */
  .positionierung {
    background: var(--pergament);
    padding: 100px 48px 60px;
    position: relative;
  }
  /* Subtle wave pattern overlay */
  .wave-pattern-bg {
    position: absolute; inset: 0; overflow: hidden; pointer-events: none;
    opacity: 0.03;
  }
  .wave-pattern-bg svg { width: 100%; height: 100%; }
  .pos-inner { max-width: 760px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }
  .pos-eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: 0.3em;
    color: var(--petrol-mist); margin-bottom: 36px;
  }
  .pos-statement {
    font-family: var(--serif); font-size: clamp(26px, 3vw, 40px);
    font-weight: 400; line-height: 1.32; color: var(--tintenblau);
  }
  .pos-statement em { font-style: italic; color: var(--petrol-mist); }
  .pos-divider {
    width: 48px; height: 1.5px; background: var(--nebelblau);
    margin: 48px auto 36px; opacity: 0.4;
  }
  .pos-body {
    font-family: var(--serif); font-size: 16px; line-height: 1.75;
    color: var(--graphit); max-width: 580px; margin: 0 auto;
  }

  /* === FELDER (light strip) === */
  .felder {
    background: var(--sandstein);
    padding: 24px 48px;
  }
  .felder-inner {
    max-width: 1240px; margin: 0 auto;
    display: flex; align-items: center; justify-content: center; gap: 48px;
    flex-wrap: wrap;
  }
  .felder-label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.26em; color: var(--petrol-mid);
  }
  .felder-list { display: flex; gap: 32px; flex-wrap: wrap; }
  .felder-list span { font-size: 12px; color: var(--petrol-mid); letter-spacing: 0.04em; font-weight: 500; }

  /* === WIRKFELDER — Schicht 2: Orientierung & Wirksamkeit === */
  .wirkfelder {
    background: var(--pergament);
    padding: 100px 48px 60px;
    position: relative;
  }
  .wf-inner { max-width: 1240px; margin: 0 auto; position: relative; z-index: 2; }
  .wf-header {
    display: grid; grid-template-columns: 0.8fr 1.2fr;
    gap: 80px; margin-bottom: 72px; align-items: end;
  }
  .wf-eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: 0.3em;
    color: var(--petrol-mist); margin-bottom: 20px;
  }
  .wf-title {
    font-family: var(--serif); font-size: clamp(28px, 3vw, 36px);
    font-weight: 400; line-height: 1.18; color: var(--tintenblau);
  }
  .wf-intro {
    font-size: 15px; line-height: 1.7; color: var(--graphit);
  }
  /* Asymmetric card layout */
  .wf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 20px;
  }
  .wf-card {
    background: white;
    padding: 40px 28px 36px;
    position: relative; overflow: hidden;
    transition: transform 300ms ease, box-shadow 300ms ease;
    border: 1px solid rgba(26,50,64,0.04);
  }
  .wf-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(26,50,64,0.08);
  }
  /* Colored top accent — thicker, more visible */
  .wf-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
  }
  .wf-card.kultur::before { background: var(--petrol-mid); }
  .wf-card.fuehrung::before { background: var(--petrol-mist); }
  .wf-card.kommunikation::before { background: var(--nebelblau); }
  /* Wave watermark inside card */
  .wf-card::after {
    content: ''; position: absolute; bottom: -20px; right: -20px;
    width: 120px; height: 60px; border-radius: 50%;
    opacity: 0.04;
  }
  .wf-card.kultur::after { background: var(--petrol-mid); }
  .wf-card.fuehrung::after { background: var(--petrol-mist); }
  .wf-card.kommunikation::after { background: var(--nebelblau); }
  .wf-number {
    font-family: var(--serif); font-style: italic;
    font-size: 32px; color: var(--himmelblau); margin-bottom: 16px;
    line-height: 1;
  }
  .wf-label { font-size: 10px; font-weight: 500; letter-spacing: 0.22em; margin-bottom: 16px; }
  .wf-card.kultur .wf-label { color: var(--petrol-mid); }
  .wf-card.fuehrung .wf-label { color: var(--petrol-mist); }
  .wf-card.kommunikation .wf-label { color: var(--nebelblau); }
  .wf-card-title {
    font-family: var(--serif); font-size: 22px; font-weight: 400;
    line-height: 1.25; color: var(--tintenblau); margin-bottom: 14px;
  }
  .wf-card-desc { font-size: 13px; line-height: 1.7; color: var(--graphit); }

  /* === ANSATZ === */
  .ansatz {
    background: var(--pergament);
    padding: 60px 48px 100px;
    position: relative;
  }
  .ansatz-inner {
    max-width: 1240px; margin: 0 auto;
    display: grid; grid-template-columns: 0.85fr 1.15fr;
    gap: 100px; align-items: start;
  }
  .ansatz-sidebar { position: sticky; top: 120px; }
  .ansatz-eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: 0.3em;
    color: var(--petrol-mist); margin-bottom: 24px;
  }
  .ansatz-title {
    font-family: var(--serif); font-size: clamp(30px, 3vw, 40px);
    font-weight: 400; line-height: 1.15; color: var(--tintenblau);
  }
  .ansatz-title em { font-style: italic; color: var(--petrol-mist); }
  .ansatz-body {
    font-family: var(--serif); font-size: 16px;
    line-height: 1.8; color: var(--graphit);
  }
  .ansatz-body p { margin-bottom: 1.3em; }
  .ansatz-body strong { font-family: var(--sans); font-weight: 500; color: var(--tintenblau); }
  .ansatz-body em { color: var(--petrol-mist); }

  /* === WERTE — Schicht 3: Entwicklung & Dynamik === */
  .werte {
    background: linear-gradient(180deg, var(--petrol-mid) 0%, var(--tintenblau) 100%);
    padding: 120px 48px 100px;
    position: relative; overflow: hidden;
  }
  /* Animated-looking wave lines in background */
  .werte-waves {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }
  .werte-waves svg {
    position: absolute; width: 140%; left: -20%;
  }
  .werte-inner { max-width: 1240px; margin: 0 auto; position: relative; z-index: 2; }
  .werte-header {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 60px; margin-bottom: 72px; align-items: end;
  }
  .werte-eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: 0.3em;
    color: var(--nebelblau); margin-bottom: 16px;
  }
  .werte-title {
    font-family: var(--serif); font-size: clamp(30px, 3vw, 40px);
    font-weight: 400; line-height: 1.15; color: var(--pergament);
  }
  .werte-subtitle {
    font-family: var(--serif); font-style: italic;
    font-size: 15px; color: var(--nebelblau); line-height: 1.65;
    max-width: 460px;
  }
  /* Werte as stacked cards instead of 5-column */
  .werte-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 2px;
  }
  .wert-item {
    background: rgba(255,255,255,0.04);
    padding: 32px 24px;
    border: 1px solid rgba(213,226,232,0.06);
    position: relative;
    transition: background 300ms ease;
  }
  .wert-item:hover { background: rgba(255,255,255,0.08); }
  .wert-schicht {
    font-size: 9px; font-weight: 500; letter-spacing: 0.22em;
    color: var(--petrol-mist); margin-bottom: 12px; text-transform: uppercase;
  }
  .wert-name {
    font-family: var(--serif); font-size: 22px; font-weight: 400;
    color: var(--pergament); margin-bottom: 8px;
  }
  .wert-verben {
    font-size: 11px; font-style: italic; color: var(--nebelblau);
    margin-bottom: 18px; line-height: 1.5;
  }
  .wert-kern { font-size: 12px; line-height: 1.6; color: var(--himmelblau); }

  /* === CTA === */
  .cta {
    background: var(--pergament);
    padding: 120px 48px 140px;
    position: relative;
  }
  .cta-inner { max-width: 720px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }
  .cta-eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: 0.3em;
    color: var(--petrol-mist); margin-bottom: 32px;
  }
  .cta-title {
    font-family: var(--serif); font-size: clamp(28px, 3vw, 40px);
    font-weight: 400; line-height: 1.28; color: var(--tintenblau);
    margin-bottom: 48px;
  }
  .cta-title em { font-style: italic; color: var(--petrol-mist); }
  .cta-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; padding: 14px 28px;
    font-size: 12px; font-weight: 500; letter-spacing: 0.06em;
    text-decoration: none; transition: all 220ms;
  }
  .btn-dark { background: var(--tintenblau); color: var(--pergament); }
  .btn-dark:hover { background: var(--petrol-mid); }
  .btn-outline {
    border: 1px solid var(--petrol-mist); color: var(--petrol-mist); background: transparent;
  }
  .btn-outline:hover { background: var(--petrol-mist); color: var(--pergament); }

  /* === FOOTER === */
  footer {
    background: var(--tintenblau); color: var(--himmelblau);
    padding: 72px 48px 36px;
    position: relative; overflow: hidden;
  }
  .footer-wave {
    position: absolute; top: 0; left: 0; width: 100%; pointer-events: none;
  }
  .footer-inner {
    max-width: 1240px; margin: 0 auto;
    display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px; margin-bottom: 48px;
    position: relative; z-index: 2;
  }
  .footer-brand-block { }
  .footer-brand {
    display: flex; align-items: center; gap: 12px; margin-bottom: 12px;
  }
  .footer-brand img { width: 36px; height: 25px; object-fit: contain; }
  .footer-brand span { font-size: 15px; font-weight: 500; color: var(--pergament); }
  .footer-cdc {
    font-size: 10px; font-weight: 500; letter-spacing: 0.34em;
    color: var(--petrol-mist); margin-bottom: 16px;
  }
  .footer-tagline {
    font-family: var(--serif); font-size: 13px; font-style: italic;
    color: var(--nebelblau); line-height: 1.6; max-width: 320px;
  }
  .footer-col h4 {
    font-size: 10px; font-weight: 500; letter-spacing: 0.2em;
    color: var(--nebelblau); margin-bottom: 16px; text-transform: uppercase;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 8px; }
  .footer-col a {
    font-size: 13px; color: var(--himmelblau); text-decoration: none; transition: color 180ms;
  }
  .footer-col a:hover { color: var(--pergament); }
  .footer-meta {
    max-width: 1240px; margin: 0 auto; padding-top: 28px;
    border-top: 1px solid rgba(142,176,192,0.1);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 11px; color: var(--petrol-mist);
    position: relative; z-index: 2;
  }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    .nav-links { display: none; }
    .hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 56px 24px 80px; }
    .hero { min-height: auto; }
    .hero-name { font-size: 36px; }
    .hero-headline { font-size: 30px; max-width: none; }
    .hero-portrait { aspect-ratio: 4/3; }
    .hero-symbol { width: 80px; }
    .positionierung { padding: 72px 24px 48px; }
    .felder { padding: 20px 24px; }
    .felder-inner { justify-content: flex-start; gap: 12px; }
    .felder-list { gap: 16px; }
    .wirkfelder { padding: 72px 24px 48px; }
    .wf-header { grid-template-columns: 1fr; gap: 24px; margin-bottom: 48px; }
    .wf-grid { grid-template-columns: 1fr; }
    .ansatz { padding: 48px 24px 72px; }
    .ansatz-inner { grid-template-columns: 1fr; gap: 36px; }
    .ansatz-sidebar { position: static; }
    .werte { padding: 72px 24px; }
    .werte-header { grid-template-columns: 1fr; gap: 24px; }
    .werte-grid { grid-template-columns: 1fr 1fr; }
    .cta { padding: 80px 24px 100px; }
    footer { padding: 48px 24px 28px; }
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-meta { flex-direction: column; gap: 10px; text-align: center; }
    .wave-transition, .wave-transition-reverse { height: 60px; }
  }
  @media (max-width: 600px) {
    .werte-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="brand-link">
      <img class="brand-logo" src="data:image/png;base64," alt="CDC">
      <span class="brand-name-nav">Dr. Stephanie Rohac</span>
    </a>
    <div class="nav-links">
      <a href="#wirkfelder">Wirkfelder</a>
      <a href="#ansatz">Ansatz</a>
      <a href="#werte">Werte</a>
      <a href="#">Publikationen</a>
      <a href="#kontakt" class="nav-cta">Kontakt</a>
    </div>
  </div>
</nav>

<!-- HERO — Tiefe & Menschlichkeit -->
<section class="hero">
  <div class="hero-wave-bg">
    <div class="hero-circle-1"></div>
    <div class="hero-circle-2"></div>
    <!-- Subtle wave lines -->
    <svg viewBox="0 0 1440 400" preserveAspectRatio="none" style="bottom: 40px; opacity: 0.06;">
      <path d="M0 280 Q360 240 720 280 T1440 260" stroke="#8EB0C0" stroke-width="1.5" fill="none"/>
      <path d="M0 310 Q360 270 720 310 T1440 290" stroke="#4A7C8E" stroke-width="1" fill="none"/>
      <path d="M0 340 Q360 300 720 340 T1440 320" stroke="#D5E2E8" stroke-width="0.8" fill="none"/>
    </svg>
    <svg viewBox="0 0 1440 400" preserveAspectRatio="none" style="bottom: 120px; opacity: 0.04;">
      <path d="M0 200 Q480 170 960 210 T1440 190" stroke="#8EB0C0" stroke-width="1" fill="none"/>
    </svg>
  </div>
  <div class="hero-inner">
    <div>
      <!-- Brand Hierarchy: Symbol → Name → CDC → Role -->
      <img class="hero-symbol" src="data:image/png;base64," alt="Culture Drives Change Symbol">
      <div class="hero-brand">
        <div class="hero-name">Dr. Stephanie<br>Rohac</div>
        <div class="hero-cdc">CULTURE&nbsp;&nbsp;DRIVES&nbsp;&nbsp;CHANGE</div>
        <div class="hero-role">VORDENKERIN &nbsp;&middot;&nbsp; GESTALTERIN</div>
      </div>
      <h1 class="hero-headline">Wandel beginnt <em>unter der Oberfl&auml;che.</em></h1>
      <svg class="hero-flow" viewBox="0 0 200 18" width="200" height="18" aria-hidden="true">
        <path d="M 2 11 Q 42 4, 82 10 T 162 10 L 198 10" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/>
      </svg>
      <p class="hero-sub">Psychologisch fundiert, strategisch klar, menschlich getragen &mdash; Transformation im KI-Zeitalter wirksam gestaltbar machen.</p>
    </div>
    <div class="hero-portrait">
      <div class="hero-portrait-ph">Portraitfoto<br>Dr. Stephanie Rohac</div>
    </div>
  </div>
</section>

<!-- WAVE: Tintenblau → Pergament -->
<div class="wave-transition" style="background: var(--tintenblau);">
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
    <path d="M0 0 L0 40 Q240 100 480 70 T960 80 T1440 50 L1440 0 Z" fill="var(--tintenblau)"/>
    <path d="M0 40 Q240 100 480 70 T960 80 T1440 50 L1440 120 L0 120 Z" fill="var(--pergament)"/>
  </svg>
</div>

<!-- POSITIONIERUNG -->
<section class="positionierung">
  <div class="wave-pattern-bg">
